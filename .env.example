# Copy file này thành `.env` (cùng thư mục) trên VPS rồi điền giá trị thật.
# .env KHÔNG commit vào git (đã có .gitignore).

# Server
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgres://asinu_user:asinu_secure_password_2026@asinu_postgres:5432/asinu_db

# Redis
REDIS_URL=redis://asinu_redis:6379

# Auth
JWT_SECRET=change_me_in_production

# AI provider (openai | anthropic | medgemma | ...)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Chatbot feature flags (MVP audit FIX #1) ─────────────────────
# Turn the chatbot endpoint on/off without redeploying.
CHATBOT_ENABLED=false
CHATBOT_PREMIUM_ONLY=true
CHATBOT_DAILY_LIMIT_FREE=0
CHATBOT_DAILY_LIMIT_PREMIUM=20
CHATBOT_MONTHLY_TOKEN_LIMIT_FREE=0
CHATBOT_MONTHLY_TOKEN_LIMIT_PREMIUM=200000

# Care Circle anti-abuse (MVP audit FIX #5)
PHONE_SEARCH_DAILY_LIMIT=20

# Operational
# HEALTH_CHECK_TOKEN=
# SENTRY_DSN=
# LOG_LEVEL=info
# LOG_FORMAT=json
# SLOW_QUERY_MS=100

# Public URL (dùng để generate links trong email/notification)
BACKEND_PUBLIC_URL=https://asinu.top

# SePay (payment gateway) — optional
# SEPAY_ACCOUNT_NUMBER=
# SEPAY_BANK_CODE=
# SEPAY_API_KEY=
