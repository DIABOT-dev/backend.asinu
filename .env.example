# Copy file này thành `.env` (cùng thư mục) trên VPS rồi điền giá trị thật.
# .env KHÔNG commit vào git (đã có .gitignore).

# Server
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgres://asinu_user:asinu_secure_password_2026@asinu_postgres:5432/asinu_db

# Redis
REDIS_URL=redis://asinu_redis:6379

# Auth
JWT_SECRET=change_me_in_production

# =================================================================
# AI providers
# =================================================================
# Asinu chia AI thành 2 surfaces:
#   1. Chatbot tự do            → AI_PROVIDER  (rẻ, dùng OpenAI / Gemini)
#   2. Clinical reasoning       → AI_PROVIDER_CLINICAL + SYMPTOM_AI_PROVIDER
#      (triage, symptom analyzer, alert filter, script generation —
#       NÊN dùng MedGemma vì train cho dữ liệu y tế).
#
# Giá trị hợp lệ: openai | medgemma | gemini | diabrain
AI_PROVIDER=openai
AI_PROVIDER_CLINICAL=openai
OPENAI_API_KEY=sk-...

# Symptom analyzer router (dùng riêng để A/B clinical mà không đụng chatbot).
# Khi đặt `medgemma` + MEDGEMMA_ENDPOINT đã cấu hình → mọi cuộc gọi
# analyzeSymptom() và quickUrgencyCheck() đi qua MedGemma.
# Không set → fallback về OpenAI (gpt-4o-mini).
SYMPTOM_AI_PROVIDER=openai
SYMPTOM_AI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------
# MedGemma (Google Health AI) — clinical reasoning provider
# -----------------------------------------------------------------
# Để TRỐNG → MedGemma DISABLED, hệ thống dùng OpenAI cho mọi luồng.
#
# Khi có endpoint thật (Vertex AI / self-host / Replicate / Together),
# uncomment 3 dòng dưới + điền giá trị, rồi đổi:
#   SYMPTOM_AI_PROVIDER=medgemma
#   AI_PROVIDER_CLINICAL=medgemma
# Restart backend: `docker compose restart asinu-backend`
#
# MEDGEMMA_ENDPOINT=https://us-central1-aiplatform.googleapis.com/v1/projects/PROJECT/locations/us-central1/endpoints/ENDPOINT:predict
# MEDGEMMA_API_KEY=
# MEDGEMMA_MODEL=medgemma-27b-text-it

# Gemini (Google AI Studio) — alternative chatbot provider.
# Bật khi muốn so sánh chất lượng với OpenAI, hoặc khi OpenAI quota cạn.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Chatbot feature flags (MVP audit FIX #1) ─────────────────────
# Turn the chatbot endpoint on/off without redeploying.
CHATBOT_ENABLED=false
CHATBOT_PREMIUM_ONLY=true
CHATBOT_DAILY_LIMIT_FREE=0
CHATBOT_DAILY_LIMIT_PREMIUM=20
CHATBOT_MONTHLY_TOKEN_LIMIT_FREE=0
CHATBOT_MONTHLY_TOKEN_LIMIT_PREMIUM=200000

# Care Circle anti-abuse (MVP audit FIX #5)
PHONE_SEARCH_DAILY_LIMIT=20

# Script regeneration monthly quota (MVP audit FIX #2)
SCRIPT_REGEN_LIMIT_FREE=2
SCRIPT_REGEN_LIMIT_PREMIUM=10

# Care Circle feature flags (MVP audit FIX #6)
CARE_CIRCLE_ENABLED=true
CARE_CIRCLE_FREE_LIMIT=1
CARE_CIRCLE_PREMIUM_LIMIT=3
CAREGIVER_ALERT_ENABLED=true
CAREGIVER_VIEW_LOGS_ENABLED=true
CAREGIVER_HISTORY_DAYS_FREE=30
CAREGIVER_HISTORY_DAYS_PREMIUM=365
CAREGIVER_ACK_ENABLED=true

# Check-in flow (MVP audit lỗi 7).
# 'ai'     = current FE flow, /checkin/start + /checkin/triage (1+ AI calls per check-in)
# 'script' = cheaper script-driven flow, /checkin/script/* (0 AI calls when a cached script matches)
# Once the FE picker lands, flip per cohort to A/B the cost saving.
CHECKIN_MODE=ai

# Chat retention windows (MVP audit FIX #9 — pricing-card alignment)
CHAT_RETENTION_DAYS_FREE=30
CHAT_RETENTION_DAYS_PREMIUM=365
CHAT_HISTORY_LIMIT_FREE=50
CHAT_HISTORY_LIMIT_PREMIUM=300

# Operational
# HEALTH_CHECK_TOKEN=
# SENTRY_DSN=
# LOG_LEVEL=info
# LOG_FORMAT=json
# SLOW_QUERY_MS=100

# Public URL (dùng để generate links trong email/notification)
BACKEND_PUBLIC_URL=https://asinu.top

# SePay (payment gateway) — optional
# SEPAY_ACCOUNT_NUMBER=
# SEPAY_BANK_CODE=
# SEPAY_API_KEY=

# =================================================================
# IN-APP PURCHASE (Apple App Store + Google Play Billing)
# =================================================================
# Bật khi mobile client đặt EXPO_PUBLIC_PAYMENT_METHOD=iap.
# Xem chi tiết từng bước trong IAP_SETUP_GUIDE.md ở root repo.

# --- Apple ---
# Bundle ID (PHẢI khớp app.json → ios.bundleIdentifier).
APPLE_BUNDLE_ID=com.asinu.lite

# ID số của app trên App Store (App Store Connect → App Information → Apple ID).
# Optional ở môi trường sandbox, BẮT BUỘC ở production để chain check.
APPLE_APP_APPLE_ID=

# Môi trường StoreKit. 'sandbox' khi test với Sandbox Tester.
# Đổi sang 'production' ngay khi app đã live trên App Store.
APPLE_IAP_ENV=sandbox

# Thư mục chứa các file Apple Root CA (.cer). Mặc định: ./certs/apple
# Tải về từ https://www.apple.com/certificateauthority/ — tối thiểu cần
# AppleRootCA-G3.cer (StoreKit 2 JWS).
APPLE_ROOT_CA_DIR=

# --- Google ---
# Package name (PHẢI khớp app.json → android.package).
GOOGLE_PLAY_PACKAGE_NAME=com.asinu.lite

# Service Account JSON — có thể là đường dẫn file hoặc inline JSON.
# Tạo trong Google Cloud Console + grant trên Play Console (xem doc).
# Ví dụ inline: GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Ví dụ path:   GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=/etc/secrets/asinu-play-sa.json
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# Product IDs — để client + backend dùng chung một nguồn. Sửa cùng giá trị
# trên cả 2 store và biến EXPO_PUBLIC_IAP_PRODUCT_* của client.
IAP_PRODUCT_MONTHLY=asinu.premium.monthly
IAP_PRODUCT_YEARLY=asinu.premium.yearly
