# Copy file này thành `.env` (cùng thư mục) trên VPS rồi điền giá trị thật.
# .env KHÔNG commit vào git (đã có .gitignore).

# Server
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgres://asinu_user:asinu_secure_password_2026@asinu_postgres:5432/asinu_db

# Redis
REDIS_URL=redis://asinu_redis:6379

# Auth
JWT_SECRET=change_me_in_production

# AI provider (openai | medgemma | gemini | diabrain)
# AI_PROVIDER is the chatbot provider (the free-form chat surface).
# Clinical decisions (triage, symptom analysis, alert filter, script
# generation) should run through MedGemma when configured — set
# AI_PROVIDER_CLINICAL=medgemma to route them.
AI_PROVIDER=openai
AI_PROVIDER_CLINICAL=openai
OPENAI_API_KEY=sk-...

# MedGemma (Google Health AI) — leave unset to disable.
# MEDGEMMA_ENDPOINT=https://us-central1-aiplatform.googleapis.com/v1/projects/PROJECT/locations/us-central1/endpoints/ENDPOINT:predict
# MEDGEMMA_API_KEY=
# MEDGEMMA_MODEL=medgemma-27b-text-it

# Chatbot feature flags (MVP audit FIX #1) ─────────────────────
# Turn the chatbot endpoint on/off without redeploying.
CHATBOT_ENABLED=false
CHATBOT_PREMIUM_ONLY=true
CHATBOT_DAILY_LIMIT_FREE=0
CHATBOT_DAILY_LIMIT_PREMIUM=20
CHATBOT_MONTHLY_TOKEN_LIMIT_FREE=0
CHATBOT_MONTHLY_TOKEN_LIMIT_PREMIUM=200000

# Care Circle anti-abuse (MVP audit FIX #5)
PHONE_SEARCH_DAILY_LIMIT=20

# Script regeneration monthly quota (MVP audit FIX #2)
SCRIPT_REGEN_LIMIT_FREE=2
SCRIPT_REGEN_LIMIT_PREMIUM=10

# Care Circle feature flags (MVP audit FIX #6)
CARE_CIRCLE_ENABLED=true
CARE_CIRCLE_FREE_LIMIT=1
CARE_CIRCLE_PREMIUM_LIMIT=3
CAREGIVER_ALERT_ENABLED=true
CAREGIVER_VIEW_LOGS_ENABLED=true
CAREGIVER_HISTORY_DAYS_FREE=30
CAREGIVER_HISTORY_DAYS_PREMIUM=365
CAREGIVER_ACK_ENABLED=true

# Check-in flow (MVP audit lỗi 7).
# 'ai'     = current FE flow, /checkin/start + /checkin/triage (1+ AI calls per check-in)
# 'script' = cheaper script-driven flow, /checkin/script/* (0 AI calls when a cached script matches)
# Once the FE picker lands, flip per cohort to A/B the cost saving.
CHECKIN_MODE=ai

# Chat retention windows (MVP audit FIX #9 — pricing-card alignment)
CHAT_RETENTION_DAYS_FREE=30
CHAT_RETENTION_DAYS_PREMIUM=365
CHAT_HISTORY_LIMIT_FREE=50
CHAT_HISTORY_LIMIT_PREMIUM=300

# Operational
# HEALTH_CHECK_TOKEN=
# SENTRY_DSN=
# LOG_LEVEL=info
# LOG_FORMAT=json
# SLOW_QUERY_MS=100

# Public URL (dùng để generate links trong email/notification)
BACKEND_PUBLIC_URL=https://asinu.top

# SePay (payment gateway) — optional
# SEPAY_ACCOUNT_NUMBER=
# SEPAY_BANK_CODE=
# SEPAY_API_KEY=
